{% assign settings = shop.metafields.cookie_consent.settings.value %}

{% if settings and settings.enabled %}
  <div
    id="cookie-consent-settings"
    data-settings='{{ settings | json }}'
    style="display:none;">
  </div>

  {{ 'cookie-consent.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'cookie-consent.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Cookie Consent Banner",
  "target": "section",
  "settings": []  
}
 {% endschema %}